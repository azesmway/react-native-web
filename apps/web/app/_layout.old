const TopScreenComponent = lazy(() => import('app-top-web'))

const TopScreenComponentLoad = ({ children }: any) => {
  return (
    <Suspense>
      <TopScreenComponent>{children}</TopScreenComponent>
    </Suspense>
  )
}

const AppRootComponent = lazy(() => import('app-root-web'))

const AppRootComponentLoad = ({ children }: any) => {
  return (
    <Suspense>
      <AppRootComponent>{children}</AppRootComponent>
    </Suspense>
  )
}

export default function RootLayout() {
  const colorScheme = useColorScheme()
  const [isLoading, setLoading] = useState(false)
  const module = useRef(null)

  const [loaded] = useFonts({
    SpaceMono: require('../assets/fonts/SpaceMono-Regular.ttf')
  })

  useEffect(() => {
    if (loaded) {
      SplashScreen.hideAsync().then()
    }
  }, [loaded])

  useEffect(() => {
    const setData = async () => {
      const appcore = await import('app-core-web')
      // const { theme } = await import('app-utils-web')

      Object.assign(window, {
        onlinetur: {
          storage: appcore.storage,
          constants: appcore.constants,
          device: {
            manufacturer,
            phone_model: modelName,
            vers_os: osVersion,
            // @ts-ignore
            vers_app: Constants.expoConfig.version,
            // @ts-ignore
            url: `&manufacturer=${manufacturer}&phone_model=${modelName}&vers_os=${osVersion}&vers_app=${Constants.expoConfig.version}`
          },
          theme: appcore.theme,
          params: {},
          props: {},
          state: {},
          ratingHotels: [],
          chatRef: {},
          currentComponent: {}
        }
      })

      // @ts-ignore
      const { setAppConfig } = window.onlinetur.storage
      // @ts-ignore
      setAppConfig(Constants.expoConfig.onlinetur)
    }

    setData().then(async () => {
      setLoading(true)
    })
  }, [])

  // useEffect(() => {
  //   const setTheme = async () => {
  //     const { theme } = await import('app-utils-web')
  //
  //     if (theme) {
  //       setAppTheme(theme)
  //     }
  //   }
  //
  //   setTheme().then()
  // }, [])

  // if (!__DEV__) {
  //   VKID.Config.init({
  //     // @ts-ignore
  //     app: '52028515', // Идентификатор приложения.
  //     redirectUrl: 'https://web.onlinetur.ru/profile', // Адрес для перехода после авторизации.
  //     state: 'dj29fnsadjsd82', // Произвольная строка состояния приложения.
  //     codeVerifier: 'FGH767Gd65', // Верификатор в виде случайной строки. Обеспечивает защиту передаваемых данных.
  //     scope: 'offline email phone wall groups friends', // Список прав доступа, которые нужны приложению.
  //     mode: VKID.ConfigAuthMode.InNewTab // По умолчанию авторизация открывается в новой вкладке.
  //   })
  // }

  // <BrowserRouter>
  //   <Provider store={store}>
  //     <PersistGate loading={<Loading />} onBeforeLift={onBeforeLift} persistor={persistor}>
  //       <NotificationsProvider>
  //         <GestureHandlerRootView style={{ flex: 1 }}>
  //           <ThemeProvider value={colorScheme === 'dark' ? DarkTheme : DefaultTheme}>
  //             <PProvider>
  //                 <ImageBackground source={bgImage} style={{ flex: 1 }}>
  //                   <AppRoot>

  // </AppRoot>
  //   <ThemesModal />
  // </ImageBackground>
  // </PProvider>
  // </ThemeProvider>
  // </GestureHandlerRootView>
  // </NotificationsProvider>
  //   <ATopLevelComponent />
  //   <AlertRoot />
  // </PersistGate>
  // </Provider>
  // </BrowserRouter>

  if (!isLoading) {
    return <></>
  }

  // @ts-ignore
  const { theme } = window.onlinetur

  return (
    <>
      <TopScreenComponentLoad>
        <AppRootComponentLoad>
          <ThemeProvider value={colorScheme === 'light' ? theme.light : theme.dark}>
            <Stack
              screenOptions={{
                headerShown: true,
                headerShadowVisible: true,
                title: '',
                headerStyle: {
                  // @ts-ignore
                  height: 50
                }
              }}
            />
          </ThemeProvider>
        </AppRootComponentLoad>
      </TopScreenComponentLoad>
    </>
  )
}
